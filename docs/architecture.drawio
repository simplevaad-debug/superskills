        <mxCell id="flow-steps" value="&lt;div style='text-align:left;color:#c9d1d9;font-size:11px;line-height:1.6;font-family:Inter;'&gt;&lt;span style='color:#D97757;font-weight:bold;'&gt;1.&lt;/span&gt; User visits landing page (Next.js on Vercel) &amp;nbsp;→&amp;nbsp; &lt;span style='color:#D97757;font-weight:bold;'&gt;2.&lt;/span&gt; Clicks &quot;Get SuperSkills&quot; → POST /api/stripe/checkout → Stripe Session&lt;br&gt;&lt;span style='color:#D97757;font-weight:bold;'&gt;3.&lt;/span&gt; Stripe redirects to /success?session_id=xxx &amp;nbsp;→&amp;nbsp; &lt;span style='color:#D97757;font-weight:bold;'&gt;4.&lt;/span&gt; Success page calls stripe.checkout.sessions.retrieve() to verify&lt;br&gt;&lt;span style='color:#D97757;font-weight:bold;'&gt;5.&lt;/span&gt; If paid → HMAC-signed download token generated (24h expiry) &amp;nbsp;→&amp;nbsp; &lt;span style='color:#D97757;font-weight:bold;'&gt;6.&lt;/span&gt; User clicks Download → GET /api/download?token=xxx&lt;br&gt;&lt;span style='color:#D97757;font-weight:bold;'&gt;7.&lt;/span&gt; Server validates HMAC → redirects to Vercel Blob signed URL &amp;nbsp;→&amp;nbsp; &lt;span style='color:#D97757;font-weight:bold;'&gt;8.&lt;/span&gt; Stripe webhook POST confirms payment async&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;spacingLeft=12;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="340" y="690" width="580" height="85" as="geometry" />
        </mxCell>

